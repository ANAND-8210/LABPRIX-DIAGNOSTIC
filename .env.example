PORT=10000

# Optional persistent storage for Render production use.
# If using MongoDB Atlas from Render, also allowlist these Render outbound ranges
# in Atlas Network Access:
# 74.220.50.0/24
# 74.220.58.0/24
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/blood-booking

# Choose one: twilio or cloud
WHATSAPP_PROVIDER=twilio

# Shared destination for booking alerts. Used by both providers unless a provider-specific
# override is set below.
WHATSAPP_NOTIFY_TO=+918454822399

# Twilio WhatsApp settings
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Optional override. Defaults to WHATSAPP_NOTIFY_TO when left blank.
TWILIO_WHATSAPP_TO=whatsapp:+918454822399

# WhatsApp Cloud API settings
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_CLOUD_TOKEN=YOUR_WHATSAPP_CLOUD_TOKEN
WHATSAPP_CLOUD_VERSION=v23.0
# Optional override. Defaults to WHATSAPP_NOTIFY_TO when left blank.
WHATSAPP_CLOUD_TO=918454822399
