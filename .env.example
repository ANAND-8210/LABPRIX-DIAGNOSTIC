PORT=10000

# Optional persistent storage for Render production use.
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/blood-booking

# Choose one: twilio or cloud
WHATSAPP_PROVIDER=twilio

# Twilio WhatsApp settings
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Destination is the clinic WhatsApp number 84548 22399
TWILIO_WHATSAPP_TO=whatsapp:+918454822399

# WhatsApp Cloud API settings
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_CLOUD_TOKEN=YOUR_WHATSAPP_CLOUD_TOKEN
WHATSAPP_CLOUD_VERSION=v23.0
